# ----------------------------------------------------------------------
# Devbox & Local Environment
# ----------------------------------------------------------------------
# Ignore the devbox hidden directory which contains local state and packages
.devbox/
.direnv/

# ----------------------------------------------------------------------
# Terraform
# ----------------------------------------------------------------------
# Local .terraform directories (Contains heavy provider plugins)
**/.terraform/*

# .tfstate files (CRITICAL: Do not commit state files, they contain secrets!)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore .tfvars files because they contain sensitive data (like your public IP)
*.tfvars
*.tfvars.json
# Exception: You can allow a template file to show recruiters the required variables
!example.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ----------------------------------------------------------------------
# Kluctl & Kubernetes
# ----------------------------------------------------------------------
# Kluctl caches and external dependencies
.kluctl-cache/
.kluctl-ext/

# Prevent accidental commit of cluster credentials
kubeconfig
*.kubeconfig
.kube/

# ----------------------------------------------------------------------
# OS & Editor
# ----------------------------------------------------------------------
# Windows (Since you are working from a Windows machine)
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# MacOS (Good practice for open-source/team projects)
.DS_Store

# IDEs
.vscode/
.idea/
*.swp